{
  "compilerOptions": {
    // Completeness
    "skipLibCheck": true,
    // Emit
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "",
    // Language and Environment
    "lib": ["ESNext"],
    "target": "ESNext",
    // Modules
    "allowImportingTsExtensions": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "#font/*": ["./src/regex/font/*"],
      "#regex/*": ["./src/regex/*"],
      "#shared/*": ["./src/shared/*"]
    },
    "rootDir": "src",
    "types": ["vitest"],
    // Projects
    "disableReferencedProjectLoad": true
  }
}
